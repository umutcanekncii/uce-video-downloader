{
  "manifest_version": 3,
  "name": "UCE - Video downloader",
  "version": "1.0.0",
  "description": "Universal video detector and downloader for Chrome, Edge, and Opera.",
  "permissions": [
    "downloads",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*.googlevideo.com/*",
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.cdninstagram.com/*",
    "*://*.vimeo.com/*",
    "*://*.vimeocdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-isolated.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "UCE - Video downloader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
